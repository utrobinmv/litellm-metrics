#!/usr/bin/env bash
# Активирует виртуальное окружение litellm-metrics
#
# ИСПОЛЬЗОВАНИЕ:
#   source .venv      (или . .venv)
# НЕ запускать как:  ./venv  — это создаст подпроцесс, окружение сразу исчезнет!

if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    echo "Ошибка: запускай через source:  source .venv"
    exit 1
fi

source ~/workspace/venvs/litellm-metrics/default/bin/activate
