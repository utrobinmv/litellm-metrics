# LiteLLM Metrics — configuration template
# Copy to .env and fill in your values:
#   cp .env.example .env

# URL of the LiteLLM proxy /metrics endpoint (trailing slash required)
LITELLM_METRICS_URL=http://localhost:4000/metrics/

# Base URL of the LiteLLM proxy (for reference)
LITELLM_BASE_URL=http://localhost:4000

# API key for authentication (optional)
LITELLM_API_KEY=

# Dashboard refresh interval in seconds
REFRESH_INTERVAL=2
